---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import ScoreBar from '../components/ScoreBar.astro';

const editors = [
    {
        name: "Vítor",
        role: "Literature & Narrative",
        website: "vitorramalhosaferreira.com",
        url: "https://vitorramalhosaferreira.com",
        vintage: "1993",
        bio: "Literary studies, data science, and an enduring interest in how language shapes taste. Curious, restless, occasionally over-extracted. Benefits from air.",
        song: "https://open.spotify.com/track/1vr6OT3o3Amd1SXCr5TlWh",
        metrics: { liveliness: 2, drinkability: 2, balance: 2, complexity: 2, emotion: 2 },
        total: "10/10",
    },
    {
        name: "Catarina",
        role: "Landscape & Terroir",
        website: "catarinapatoiloteixeira.com",
        url: "https://catarinapatoiloteixeira.com",
        vintage: "1993",
        bio: "Landscape architect with a close eye on place, ecology, and the structures behind what we taste. Grounded, precise, and usually responsible for bringing the blend back into balance.",
        song: "https://open.spotify.com/track/6rCF7J07DTXu6xHwpNk2mQ",
        metrics: { liveliness: 2, drinkability: 2, balance: 2, complexity: 2, emotion: 2 },
        total: "10/10",
    }
];
---

<MainLayout title="About | Enoversa">
    <Navigation />

    <main id="main-content" class="min-h-screen pt-28 md:pt-32 px-6 md:px-24 pb-24 md:pb-32">
        
        <header class="max-w-7xl mx-auto mb-32 border-b border-line pb-12">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end">
                <div>
                    <span class="font-mono text-xs text-accent uppercase tracking-widest mb-4 block">About</span>
                    <h1 class="text-5xl md:text-7xl font-light tracking-tighter text-white">Human <span class="italic font-serif text-text-dim">Terroir.</span></h1>
                </div>
                <p class="text-text-muted font-light text-right mt-4 md:mt-0 max-w-sm">
                    Two editors. Both awarded 10/10 by an entirely independent panel.
                </p>
            </div>
        </header>

        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-x-24 gap-y-16">
            {editors.map((editor, index) => (
                <article class="border-t border-line pt-8">
                    <div class="flex items-center justify-between gap-4">
                        <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest">
                            0{index + 1} / Editor
                        </span>
                        <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest">
                            Vintage {editor.vintage}
                        </span>
                    </div>

                    <h2 class="mt-8 text-4xl md:text-5xl font-light text-white">
                        {editor.name}
                    </h2>
                    <p class="mt-2 font-mono text-xs text-accent uppercase tracking-widest">
                        {editor.role}
                    </p>

                    <p class="mt-8 max-w-xl text-lg text-text-muted font-light leading-relaxed">
                        {editor.bio}
                    </p>

                    <div class="mt-10 p-6 md:p-8 bg-surface/30 border border-line/60 rounded-sm">
                        <div class="flex items-start justify-between gap-6 mb-8 pb-5 border-b border-line">
                            <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest">
                                The Tasting Index
                            </span>
                            <a
                                href={editor.song}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group/song text-right"
                                aria-label={`Play ${editor.name}'s 10 out of 10 song on Spotify`}
                                title={`Play ${editor.name}'s 10/10 song`}
                            >
                                <span class="block text-3xl font-medium text-white leading-none group-hover/song:text-accent transition-colors">
                                    {editor.total}
                                </span>
                                <span class="mt-2 block font-mono text-[9px] uppercase tracking-widest text-text-dim group-hover/song:text-accent transition-colors">
                                    Play score ↗
                                </span>
                            </a>
                        </div>

                        <div class="space-y-4">
                            <div class="flex justify-between items-center gap-4"><span class="text-xs font-mono text-text-main uppercase">01 Energy</span><ScoreBar score={editor.metrics.liveliness} /></div>
                            <div class="flex justify-between items-center gap-4"><span class="text-xs font-mono text-text-main uppercase">02 Drinkability</span><ScoreBar score={editor.metrics.drinkability} /></div>
                            <div class="flex justify-between items-center gap-4"><span class="text-xs font-mono text-text-main uppercase">03 Balance</span><ScoreBar score={editor.metrics.balance} /></div>
                            <div class="flex justify-between items-center gap-4"><span class="text-xs font-mono text-text-main uppercase">04 Complexity</span><ScoreBar score={editor.metrics.complexity} /></div>
                            <div class="flex justify-between items-center gap-4"><span class="text-xs font-mono text-text-main uppercase">05 Emotion</span><ScoreBar score={editor.metrics.emotion} /></div>
                        </div>
                    </div>

                    <div class="mt-6 pt-4 border-t border-line">
                        <a
                            href={editor.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="min-h-11 inline-flex items-center font-mono text-[10px] text-text-dim hover:text-white transition-colors"
                        >
                            {editor.website} ↗
                        </a>
                    </div>
                </article>
            ))}
        </div>

    </main>
</MainLayout>
