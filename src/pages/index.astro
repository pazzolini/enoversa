---
import MainLayout from "../layouts/MainLayout.astro";
import Navigation from "../components/Navigation.astro";
import PlacesMap from "../components/PlacesMap.astro";
import { getCollection } from "astro:content";
import { comparePlaces } from "../utils/placeSort";

const allSelections = await getCollection("selections");
const featuredSelections = allSelections
    .sort((a, b) => b.data.tastingDate.valueOf() - a.data.tastingDate.valueOf())
    .slice(0, 2);

const allPortraits = await getCollection("portraits");
const featuredPortraits = allPortraits
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 2);

const allEssays = await getCollection("essays");
const featuredEssays = allEssays
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 2);

const featuredPlaces = (await getCollection("places"))
    .sort(comparePlaces);

import { getMoodColor } from "../utils/moodColors";

const formatPortraitDate = (date: Date) => new Intl.DateTimeFormat("en", {
    month: "long",
    year: "numeric",
}).format(date);

const legacyUrl = "https://legacy.enoversa.com";
---

<MainLayout title="Enoversa | Narratives of Soil & Craft">
    <Navigation />

    <main id="main-content">
        <header
            class="min-h-[100svh] flex flex-col justify-center px-6 md:px-24 pt-20 pb-20 md:pb-32 relative border-b border-line"
        >
            <div class="max-w-7xl w-full">
                <div class="mb-12 flex items-center gap-4">
                    <span class="w-2 h-2 bg-accent rounded-full animate-pulse"
                    ></span>
                    <span
                        class="font-mono text-xs text-text-muted tracking-widest uppercase"
                        >Vol. II — 2026</span
                    >
                </div>

                <h1
                    class="text-5xl sm:text-6xl md:text-8xl lg:text-9xl font-light leading-[0.92] tracking-tighter mb-12 md:mb-16"
                >
                    Narratives<br />
                    of <span class="text-text-dim italic font-serif font-thin"
                        >Soil & Craft.</span
                    >
                </h1>

                <div
                    class="grid grid-cols-1 md:grid-cols-12 gap-8 w-full items-end"
                >
                    <div
                        class="md:col-start-5 md:col-span-8 flex flex-col gap-8"
                    >
                        <p
                            class="text-xl md:text-2xl font-light text-text-muted leading-none"
                        >
                            Independent notes on low-intervention wines, and on
                            the people and ideas around them.
                        </p>

                        <div class="flex flex-col gap-4">
                            <div class="w-px h-12 bg-line opacity-50"></div>

                            <p
                                class="font-mono text-[10px] text-text-dim uppercase tracking-widest"
                            >
                                Scroll to explore
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <section
            id="new-beginning"
            class="px-6 md:px-24 py-20 md:py-48 border-b border-line"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-12 max-w-7xl mx-auto"
            >
                <div class="md:col-span-3 relative">
                    <div class="sticky-label">
                        <span class="font-mono text-xs text-accent mb-2 block"
                            >00</span
                        >
                        <h2
                            class="text-sm font-medium tracking-widest uppercase text-text-muted"
                        >
                            A New Beginning
                        </h2>
                    </div>
                </div>

                <div class="md:col-span-8 md:col-start-5">
                    <div class="space-y-12 max-w-3xl">
                        <p class="text-3xl md:text-4xl font-light leading-snug">
                            We drink to be <span class="text-accent"
                                >moved.</span
                            >
                        </p>

                        <div
                            class="text-lg font-light text-text-muted leading-relaxed space-y-8"
                        >
                            <p>
                                Enoversa began in 2017 as a record of what we
                                drank. The archive was broad by design: classic,
                                industrial, natural, and anything else that
                                seemed worth trying.
                            </p>

                            <p>
                                Over time, our attention narrowed. We kept
                                returning to wines made with fewer corrections
                                and more room for the vineyard, the vintage, and
                                the people behind them to show.
                            </p>

                            <p>
                                Volume II starts here.
                            </p>
                        </div>

                        <div
                            class="pt-12 mt-12 border-t border-line grid grid-cols-1 md:grid-cols-2 gap-12"
                        >
                            <div>
                                <span
                                    class="font-mono text-[10px] text-text-dim uppercase block mb-2"
                                    >The Editors</span
                                >
                                <span class="text-sm text-text-main block mb-2"
                                    >Vítor & Catarina</span
                                >
                                <a
                                    href="/about"
                                    class="group inline-flex items-center gap-2 text-xs text-text-dim hover:text-white transition-colors"
                                >
                                    <span
                                        class="border-b border-transparent group-hover:border-text-dim pb-0.5"
                                        >Meet us</span
                                    >
                                    <span
                                        class="transition-transform group-hover:translate-x-1"
                                        >-></span
                                    >
                                </a>
                            </div>

                            <div>
                                <span
                                    class="font-mono text-[10px] text-text-dim uppercase block mb-2"
                                    >The Tasting Index</span
                                >
                                <span class="text-sm text-text-main block mb-2"
                                    >How We Taste</span
                                >
                                <a
                                    href="/methodology"
                                    class="group inline-flex items-center gap-2 text-xs text-text-dim hover:text-white transition-colors"
                                >
                                    <span
                                        class="border-b border-transparent group-hover:border-text-dim pb-0.5"
                                        >Read the index</span
                                    >
                                    <span
                                        class="transition-transform group-hover:translate-x-1"
                                        >-></span
                                    >
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>



        <section
            id="selections"
            class="px-6 md:px-24 py-20 md:py-48 border-b border-line bg-bg"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-12 max-w-7xl mx-auto"
            >
                <div class="md:col-span-3 relative">
                    <div class="sticky-label">
                        <span class="font-mono text-xs text-accent mb-2 block"
                            >01</span
                        >
                        <h2
                            class="text-sm font-medium tracking-widest uppercase text-text-muted"
                        >
                            Selections
                        </h2>
                    </div>
                </div>
                <div class="md:col-span-9">
                    <p
                        class="text-text-muted font-light mb-12 max-w-xl text-base"
                    >
                        Wines we have spent time with, recorded with tasting
                        notes and a five-part score.
                    </p>

                    <div
                        class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-24"
                    >
                        {
                            featuredSelections.map((post) => (
                                <article class="group cursor-pointer">
                                    <a href={`/selections/${post.id}`}>
                                        <div
                                            class={`aspect-[4/3] relative mb-6 overflow-hidden flex items-center justify-center px-6 transition duration-500 group-hover:scale-[1.02] ${getMoodColor(post.data.tags[0])}`}
                                        >
                                            <h3 class="font-sans text-2xl font-medium uppercase text-center tracking-tight opacity-90 leading-tight">
                                                {post.data.vibe}
                                            </h3>
                                        </div>

                                        <div class="border-b border-line pb-6 mb-6 flex justify-between items-end">
                                            <h3 class="text-2xl font-light group-hover:text-accent transition-colors">
                                                {post.data.title}
                                            </h3>
                                            <span class="font-mono text-xs text-text-dim uppercase">
                                                {post.data.producer}
                                            </span>
                                        </div>
                                        <p class="text-text-muted font-light leading-relaxed mb-4 line-clamp-3">
                                            {post.data.excerpt}
                                        </p>
                                        <div class="flex justify-between items-center">
                                            <span
                                                class={`font-mono text-[10px] uppercase tracking-widest ${getMoodColor(post.data.tags[0])}`}
                                            >
                                                {post.data.tags[0]}
                                            </span>
                                            <span class="text-xs font-mono uppercase tracking-wider text-text-dim group-hover:text-white transition">
                                                Read Notes ->
                                            </span>
                                        </div>
                                    </a>
                                </article>
                            ))
                        }
                    </div>

                    <div class="mt-16 border-t border-line pt-8 text-right">
                        <a
                            href="/selections"
                            class="text-xs font-mono uppercase tracking-widest text-text-dim hover:text-white transition"
                            >View Full Archive -></a
                        >
                    </div>
                </div>
            </div>
        </section>

        <section
            id="portraits"
            class="px-6 md:px-24 py-20 md:py-48 border-b border-line"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-12 max-w-7xl mx-auto"
            >
                <div class="md:col-span-3 relative">
                    <div class="sticky-label">
                        <span class="font-mono text-xs text-accent mb-2 block"
                            >02</span
                        >
                        <h2
                            class="text-sm font-medium tracking-widest uppercase text-text-muted"
                        >
                            Portraits
                        </h2>
                    </div>
                </div>
                <div class="md:col-span-9">
                    <p
                        class="text-text-muted font-light mb-12 max-w-xl text-base"
                    >
                        Conversations with growers, winemakers, and people whose
                        work changes how we understand wine.
                    </p>

                    {
                        featuredPortraits.length > 0 ? (
                            <div class="border-t border-line">
                                {featuredPortraits.map((post, index) => (
                                    <article class="group border-b border-line">
                                        <a
                                            href={`/portraits/${post.id}`}
                                            class="grid grid-cols-1 md:grid-cols-9 gap-5 md:gap-8 py-8 md:py-10"
                                        >
                                            <div class="md:col-span-2 flex md:block justify-between">
                                                <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-accent">
                                                    Portrait / {String(index + 1).padStart(2, '0')}
                                                </span>
                                                <span class="md:mt-10 block font-mono text-[10px] uppercase tracking-widest text-text-dim">
                                                    {formatPortraitDate(post.data.date)}
                                                </span>
                                            </div>
                                            <div class="md:col-span-5">
                                                <h3 class="text-3xl md:text-4xl font-light tracking-tight text-white group-hover:text-accent transition-colors">
                                                    {post.data.title}
                                                </h3>
                                                <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-text-dim leading-relaxed">
                                                    <span class="block">{post.data.role}</span>
                                                    <span class="block mt-1">{post.data.location}</span>
                                                </p>
                                                <p class="mt-5 text-text-muted font-light leading-relaxed">
                                                    {post.data.excerpt}
                                                </p>
                                            </div>
                                            <div class="md:col-span-2 flex md:flex-col justify-between md:items-end gap-5">
                                                <span class="font-mono text-[10px] uppercase tracking-widest text-text-dim md:text-right">
                                                    {post.data.tags.join(' · ')}
                                                </span>
                                                <span class="font-mono text-xs uppercase tracking-wider text-text-dim group-hover:text-white transition-colors">
                                                    Read Portrait ->
                                                </span>
                                            </div>
                                        </a>
                                    </article>
                                ))}
                            </div>
                        ) : (
                            <div class="border-y border-line py-10 max-w-2xl">
                                <span class="font-mono text-[10px] uppercase tracking-widest text-accent">
                                    Volume II
                                </span>
                                <p class="mt-3 text-text-muted font-light">
                                    No new portraits have been published yet.
                                    Earlier interviews remain in the Legacy Archive.
                                </p>
                            </div>
                        )
                    }

                    <div class="mt-16 border-t border-line pt-8 text-right">
                        <a
                            href="/portraits"
                            class="text-xs font-mono uppercase tracking-widest text-text-dim hover:text-white transition"
                            >View All Portraits -></a
                        >
                    </div>
                </div>
            </div>
        </section>

        <section
            id="essays"
            class="px-6 md:px-24 py-20 md:py-48 border-b border-line"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-12 max-w-7xl mx-auto"
            >
                <div class="md:col-span-3 relative">
                    <div class="sticky-label">
                        <span class="font-mono text-xs text-accent mb-2 block"
                            >03</span
                        >
                        <h2
                            class="text-sm font-medium tracking-widest uppercase text-text-muted"
                        >
                            Essays
                        </h2>
                    </div>
                </div>
                <div class="md:col-span-9">
                    <p
                        class="text-text-muted font-light mb-12 max-w-xl text-base"
                    >
                        Longer pieces on books, places, and the culture around
                        wine.
                    </p>

                    <div>
                        {
                            featuredEssays.map((post, index) => (
                                <a
                                    href={`/essays/${post.id}`}
                                    class="group grid grid-cols-1 sm:grid-cols-12 gap-7 sm:gap-10 border-y border-line py-9 md:py-12"
                                >
                                    <div class="sm:col-span-3 flex sm:block justify-between items-start">
                                        <span class="text-5xl md:text-6xl font-light tracking-tighter text-line group-hover:text-accent transition-colors">
                                            {String(index + 1).padStart(2, '0')}
                                        </span>
                                        <div class="sm:mt-8 font-mono text-[10px] uppercase tracking-widest text-text-dim text-right sm:text-left leading-relaxed">
                                            <span class="block text-accent">{post.data.type}</span>
                                            {post.data.location && <span class="block mt-1">{post.data.location}</span>}
                                        </div>
                                    </div>

                                    <div class="sm:col-span-9">
                                        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-text-dim mb-4">
                                            Current essay
                                        </p>
                                        <h3 class="text-3xl md:text-4xl font-light tracking-tight text-white group-hover:text-accent transition-colors leading-tight">
                                            {post.data.title}
                                        </h3>
                                        <p class="mt-5 max-w-2xl text-text-muted font-light leading-relaxed">
                                            {post.data.excerpt}
                                        </p>
                                        <div class="mt-7 pt-4 border-t border-line/60 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                                            <span class="font-mono text-[10px] uppercase tracking-widest text-text-dim">
                                                {post.data.tags.join(' · ')}
                                            </span>
                                            <span class="font-mono text-[10px] uppercase tracking-widest text-text-dim group-hover:text-accent transition-colors shrink-0">
                                                Read essay →
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            ))
                        }
                    </div>

                    <div class="mt-16 border-t border-line pt-8 text-right">
                        <a
                            href="/essays"
                            class="text-xs font-mono uppercase tracking-widest text-text-dim hover:text-white transition"
                            >View All Essays -></a
                        >
                    </div>
                </div>
            </div>
        </section>

        <section
            id="addresses"
            class="px-6 md:px-24 py-20 md:py-36 border-b border-line bg-surface/40"
        >
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12 max-w-7xl mx-auto">
                <div class="md:col-span-3 relative">
                    <div class="sticky-label">
                        <span class="font-mono text-xs text-accent mb-2 block">04</span>
                        <h2 class="text-sm font-medium tracking-widest uppercase text-text-muted">
                            Addresses
                        </h2>
                    </div>
                </div>

                <div class="md:col-span-9">
                    <div class="grid grid-cols-1 lg:grid-cols-9 gap-10 lg:gap-16 mb-12">
                        <p class="lg:col-span-5 text-text-muted font-light max-w-xl text-base leading-relaxed">
                            Wineries, wine shops, bars and restaurants we would return to.
                        </p>
                        <div class="lg:col-span-4 border-l border-line pl-6 font-mono text-[10px] uppercase tracking-widest text-text-dim leading-loose">
                            <span class="block text-accent">No ratings</span>
                            <span class="block">No paid placements</span>
                            <span class="block">Only personal recommendations</span>
                        </div>
                    </div>

                    <PlacesMap places={featuredPlaces} />
                </div>
            </div>
        </section>

        <section id="legacy" class="px-6 md:px-24 py-16 md:py-24 bg-surface">
            <div
                class="grid grid-cols-1 md:grid-cols-12 gap-12 max-w-7xl mx-auto items-start"
            >
                <div class="md:col-span-3 relative">
                    <div class="sticky-label">
                        <div class="flex items-center gap-3">
                            <h2
                                class="text-xs font-medium tracking-widest uppercase text-text-dim"
                            >
                                Legacy Archive
                            </h2>
                            <span
                                class="w-1.5 h-1.5 bg-accent/50 rounded-full"
                            ></span>
                        </div>
                        <p class="font-mono text-[10px] text-text-dim mt-2 opacity-60">
                            2017 — 2023
                        </p>
                    </div>
                </div>
                <div class="md:col-span-7 md:col-start-5">
                    <div
                        class="space-y-6 text-sm font-light leading-relaxed text-text-muted/80"
                    >
                        <p>
                            The original Enoversa archive covers 2017–2023:
                            tastings, interviews, and writing on wine and art.
                        </p>
                        <p>
                            It remains online as a record of the project before
                            Volume II.
                        </p>

                        <div class="pt-4">
                            <a
                                href={legacyUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-text-dim hover:text-white transition-colors text-xs font-mono uppercase tracking-widest"
                            >
                                Visit Legacy Archive ↗
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</MainLayout>
