---
import MainLayout from "../layouts/MainLayout.astro";
import Navigation from "../components/Navigation.astro";
---

<MainLayout
    title="Page not found | Enoversa"
    description="The requested page could not be found."
>
    <Navigation />
    <main
        id="main-content"
        class="min-h-[75svh] px-6 md:px-24 pt-36 pb-24 flex items-center"
    >
        <div class="max-w-3xl">
            <span class="font-mono text-xs text-accent tracking-widest">404</span>
            <h1 class="mt-4 text-5xl sm:text-6xl md:text-8xl font-light tracking-tighter text-white">
                Off the map.
            </h1>
            <p class="mt-8 max-w-xl text-lg font-light leading-relaxed text-text-muted">
                This page may have moved, or the bottle may simply be gone.
            </p>
            <a
                href="/"
                class="mt-10 min-h-11 inline-flex items-center font-mono text-xs uppercase tracking-widest text-accent hover:text-white transition-colors"
            >
                Return home →
            </a>
        </div>
    </main>
</MainLayout>
