---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Navigation from "../../components/Navigation.astro";
import ScoreBar from "../../components/ScoreBar.astro";
import BackLink from "../../components/BackLink.astro";
import { getSelectionPalette } from "../../utils/selectionPalettes";
import {
    formatSelectionVibe,
    getSelectionTagGroups,
} from "../../utils/selectionTaxonomy";

export async function getStaticPaths() {
    const entries = await getCollection("selections");
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { metrics } = entry.data;
const tagGroups = getSelectionTagGroups(entry.data.tags);
const paletteClass = getSelectionPalette(entry.data.palette);
const classificationDetails = [
    { label: "Vintage", value: entry.data.vintage },
    { label: "Colour", value: entry.data.classification.colour },
    { label: "Effervescence", value: entry.data.classification.effervescence },
    entry.data.classification.sweetness
        ? { label: "Sweetness", value: entry.data.classification.sweetness }
        : null,
    entry.data.classification.fortified
        ? { label: "Fortification", value: "Fortified" }
        : null,
    { label: "Origin", value: `${entry.data.country} / ${entry.data.region}` },
    { label: "Grapes", value: entry.data.grapes },
    { label: "Price", value: entry.data.price },
].filter((detail): detail is { label: string; value: string } => Boolean(detail));
const serviceDetails = [
    { label: "Glass", value: entry.data.service?.glass },
    { label: "Decant", value: entry.data.service?.decant },
    { label: "Temperature", value: entry.data.service?.temperature },
    { label: "Tasted over", value: entry.data.service?.tastedOver },
].filter((detail): detail is { label: string; value: string } => Boolean(detail.value));

// Calculate Total Score
const totalScore =
    metrics.liveliness +
    metrics.drinkability +
    metrics.balance +
    metrics.complexity +
    metrics.emotion;

---

<MainLayout title={`${entry.data.title} | Enoversa`}>
    <Navigation />

    <main id="main-content" class="min-h-screen pt-28 md:pt-32 px-6 md:px-24 pb-24">
        <div class="max-w-6xl mx-auto mb-10">
            <BackLink href="/selections" label="All Selections" />
        </div>

        <!-- HEADER SECTION -->
        <header class="max-w-6xl mx-auto mb-24">
            <!-- 1. Title Row -->
            <div
                class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12"
            >
                <div>
                    <span
                        class="font-mono text-xs text-accent uppercase tracking-widest mb-2 block"
                        >{entry.data.producer}</span
                    >
                    <h1
                        class="text-4xl sm:text-5xl md:text-7xl font-light tracking-tighter text-white break-words"
                    >
                        {entry.data.title}
                    </h1>
                </div>
            </div>

            <!-- 2. The Technical Data Strip -->
            <div class="border-y border-line py-6 mb-12" data-selection-metadata>
                <div
                    class="grid grid-cols-2 md:grid-cols-4 gap-8 font-mono text-[10px] uppercase tracking-widest text-text-muted"
                >
                    {classificationDetails.map((detail) => (
                        <div>
                            <span class="block text-text-dim mb-1">{detail.label}</span>
                            <span class="text-white">{detail.value}</span>
                        </div>
                    ))}
                </div>
                {tagGroups.length > 0 && (
                    <div
                        class="mt-6 pt-6 border-t border-line/60 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-5 font-mono text-[10px] uppercase tracking-widest"
                        data-selection-tags
                    >
                        {tagGroups.map((group) => (
                            <div>
                                <span class="block text-text-dim mb-1">{group.label}</span>
                                <span class="text-white leading-relaxed">
                                    {group.values.join(" · ")}
                                </span>
                            </div>
                        ))}
                    </div>
                )}
            </div>

            <!-- 3. The Vibe Card (La Cabra Style) -->
            <div
                class={`w-full min-h-72 md:min-h-0 md:aspect-[3/1] flex items-center justify-center rounded-sm overflow-hidden p-4 md:p-6 ${paletteClass}`}
                data-selection-vibe
            >
                <h2
                    class="text-3xl md:text-4xl font-sans font-medium tracking-tight uppercase text-center max-w-4xl px-2 md:px-6"
                >
                    {formatSelectionVibe(entry.data.vibe)}
                </h2>
            </div>
        </header>

        <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- LEFT: METRICS -->
            <aside
                class="lg:col-span-4 lg:sticky lg:top-32 h-fit p-8 bg-surface/50 border border-line rounded-sm"
            >
                <div
                    class="flex justify-between items-center mb-8 border-b border-line pb-4"
                >
                    <h3
                        class="font-mono text-xs text-text-muted uppercase tracking-widest"
                    >
                        The Tasting Index
                    </h3>
                    <a
                        href="/methodology"
                        data-touch-target
                        class="inline-flex min-h-11 items-center font-mono text-[10px] text-accent hover:underline"
                        >HOW WE TASTE -></a
                    >
                </div>

                <div class="space-y-6">
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-light text-text-main"
                            >Energy</span
                        ><ScoreBar score={metrics.liveliness} />
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-light text-text-main"
                            >Drinkability</span
                        ><ScoreBar score={metrics.drinkability} />
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-light text-text-main"
                            >Balance</span
                        ><ScoreBar score={metrics.balance} />
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-light text-text-main"
                            >Complexity</span
                        ><ScoreBar score={metrics.complexity} />
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-light text-text-main"
                            >Emotion</span
                        ><ScoreBar score={metrics.emotion} />
                    </div>
                </div>

                <div class="mt-10 pt-6 border-t border-line">
                    <div class="flex justify-between items-end">
                        <span
                            class="font-mono text-xs text-text-muted uppercase tracking-widest mb-1"
                            >Total</span
                        >
                        <span
                            class="text-5xl font-light text-white leading-none"
                            >{totalScore}<span
                                class="text-lg text-text-dim font-mono ml-1"
                                >/10</span
                            ></span
                        >
                    </div>
                </div>

                {
                    serviceDetails.length > 0 && (
                        <div class="mt-8 pt-6 border-t border-line">
                            <h3 class="mb-5 font-mono text-[10px] text-text-dim uppercase tracking-widest">
                                Service
                            </h3>
                            <dl class="space-y-4">
                                {serviceDetails.map((detail) => (
                                    <div class="flex justify-between gap-4 text-xs">
                                        <dt class="font-mono text-[9px] text-text-dim uppercase tracking-widest">
                                            {detail.label}
                                        </dt>
                                        <dd class="text-right font-light text-text-main">
                                            {detail.value}
                                        </dd>
                                    </div>
                                ))}
                            </dl>
                        </div>
                    )
                }
            </aside>

            <!-- RIGHT: NARRATIVE -->
            <article
                class="lg:col-span-8 prose prose-invert prose-lg max-w-none
                prose-headings:font-light prose-headings:text-white prose-headings:mb-4 prose-headings:mt-12
                prose-p:text-text-muted prose-p:font-light prose-p:leading-relaxed prose-p:mb-6
                prose-a:text-accent hover:prose-a:text-white
                prose-strong:font-medium prose-strong:text-white
                prose-ul:list-disc prose-ul:pl-4 prose-li:text-text-muted prose-li:mb-2"
            >
                <Content />
            </article>
        </div>
    </main>
</MainLayout>
