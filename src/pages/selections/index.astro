---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Navigation from '../../components/Navigation.astro';
import { getSelectionPalette } from '../../utils/selectionPalettes';
import {
    flattenSelectionTags,
    formatSelectionVibe,
    selectionTagFacetLabels,
    selectionTagFacetOrder,
    selectionTagVocabulary,
} from '../../utils/selectionTaxonomy';

// Fetch all selections and sort by tasting date (newest first)
const allSelections = await getCollection('selections');
const sortedSelections = [...allSelections].sort((a, b) => {
    const dateDifference = b.data.tastingDate.valueOf() - a.data.tastingDate.valueOf();
    return dateDifference || a.data.title.localeCompare(b.data.title);
});

// FILTER DATA PREPARATION
const colourOrder = ['White', 'Rosé', 'Red'] as const;
const allColours = colourOrder.filter(colour =>
    allSelections.some(selection => selection.data.classification.colour === colour)
);
const effervescenceOrder = ['Still', 'Sparkling'] as const;
const allEffervescence = effervescenceOrder.filter(effervescence =>
    allSelections.some(selection => selection.data.classification.effervescence === effervescence)
);
const allCountries = [...new Set(allSelections.map(s => s.data.country))].sort();
const tagCounts = allSelections
    .flatMap(selection => flattenSelectionTags(selection.data.tags))
    .reduce((counts, tag) => {
        counts.set(tag, (counts.get(tag) ?? 0) + 1);
        return counts;
    }, new Map<string, number>());
const filterTagGroups = selectionTagFacetOrder.flatMap(facet => {
    const tags = selectionTagVocabulary[facet].filter(tag => (tagCounts.get(tag) ?? 0) >= 2);
    return tags.length
        ? [{ facet, label: selectionTagFacetLabels[facet], tags }]
        : [];
});
const priceIntervals = [
    { label: '< 30€', min: 0, max: 30 },
    { label: '30€ - 59€', min: 30, max: 60 },
    { label: '60€ - 99€', min: 60, max: 100 },
    { label: '100€ +', min: 100, max: 9999 }
];

// Helper to format date
const formatDate = (date: Date) => {
    return new Date(date).toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric'
    });
};

// Helper to parse price for data attribute
const parsePrice = (priceStr: string) => {
    return parseFloat(priceStr.replace(',', '.').replace(/[^\d.]/g, ''));
};

const getTotalScore = (metrics: typeof allSelections[number]['data']['metrics']) =>
    metrics.liveliness +
    metrics.drinkability +
    metrics.balance +
    metrics.complexity +
    metrics.emotion;
---

<MainLayout title="Selections | Enoversa">
    <Navigation />

    <main id="main-content" class="min-h-screen pt-28 md:pt-32 px-6 md:px-24 pb-24">
        
        <!-- HEADER -->
        <header class="max-w-7xl mx-auto mb-8 md:mb-12 border-b border-line pb-8 md:pb-12">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end">
                <div>
                    <span class="font-mono text-xs text-accent uppercase tracking-widest mb-4 block">01 / Index</span>
                    <h1 class="text-5xl md:text-7xl font-light tracking-tighter text-white">Selections</h1>
                </div>
                <p class="text-text-muted font-light text-left md:text-right mt-4 md:mt-0 max-w-xs">
                    {sortedSelections.length} wines, ordered by tasting date.
                </p>
            </div>

            <!-- Filter Toggle -->
            <div class="mt-8">
                <button id="filter-toggle" type="button" aria-expanded="false" aria-controls="filter-wrapper" class="min-h-11 px-4 border border-line font-mono text-[10px] text-text-dim uppercase tracking-widest hover:text-white hover:border-text-dim transition-colors flex items-center gap-2">
                    <span id="filter-toggle-text">[ FILTER ]</span>
                </button>
            </div>
        </header>

        <!-- FILTERS -->
        <div id="filter-wrapper" class="max-w-7xl mx-auto overflow-hidden transition-all duration-500 max-h-0 opacity-0 mb-12">
            <section class="space-y-5 select-none pb-8 border-b border-line/30" id="filter-container">
                <!-- Colour Filter -->
                <div class="grid grid-cols-1 sm:grid-cols-[5rem_1fr] gap-3 sm:gap-4 sm:items-center">
                    <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest opacity-50">Colour</span>
                    <div class="flex flex-wrap gap-2">
                        <button type="button" class="filter-btn min-h-11 px-4 border border-accent bg-accent text-bg font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="colour" data-value="all">All</button>
                        {allColours.map((colour) => (
                            <button type="button" class="filter-btn min-h-11 px-4 border border-line text-text-dim hover:text-white hover:border-text-dim font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="colour" data-value={colour}>{colour}</button>
                        ))}
                    </div>
                </div>

                <!-- Effervescence Filter -->
                <div class="grid grid-cols-1 sm:grid-cols-[5rem_1fr] gap-3 sm:gap-4 sm:items-center">
                    <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest opacity-50">Bubbles</span>
                    <div class="flex flex-wrap gap-2">
                        <button type="button" class="filter-btn min-h-11 px-4 border border-accent bg-accent text-bg font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="effervescence" data-value="all">All</button>
                        {allEffervescence.map((effervescence) => (
                            <button type="button" class="filter-btn min-h-11 px-4 border border-line text-text-dim hover:text-white hover:border-text-dim font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="effervescence" data-value={effervescence}>{effervescence}</button>
                        ))}
                    </div>
                </div>

                <!-- Country Filter -->
                <div class="grid grid-cols-1 sm:grid-cols-[5rem_1fr] gap-3 sm:gap-4 sm:items-center">
                    <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest opacity-50">Origin</span>
                    <div class="flex flex-wrap gap-2">
                        <button type="button" class="filter-btn min-h-11 px-4 border border-accent bg-accent text-bg font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="country" data-value="all">All</button>
                        {allCountries.map((country) => (
                            <button type="button" class="filter-btn min-h-11 px-4 border border-line text-text-dim hover:text-white hover:border-text-dim font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="country" data-value={country}>{country}</button>
                        ))}
                    </div>
                </div>

                <!-- Price Filter -->
                <div class="grid grid-cols-1 sm:grid-cols-[5rem_1fr] gap-3 sm:gap-4 sm:items-center">
                    <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest opacity-50">Price</span>
                    <div class="flex flex-wrap gap-2">
                        <button type="button" class="filter-btn min-h-11 px-4 border border-accent bg-accent text-bg font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="price" data-value="all">All</button>
                        {priceIntervals.map((interval) => (
                            <button type="button" class="filter-btn min-h-11 px-4 border border-line text-text-dim hover:text-white hover:border-text-dim font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="price" data-value={JSON.stringify({min: interval.min, max: interval.max})}>{interval.label}</button>
                        ))}
                    </div>
                </div>

                {filterTagGroups.length > 0 && (
                    <>
                        <div class="grid grid-cols-1 sm:grid-cols-[5rem_1fr] gap-3 sm:gap-4 sm:items-center">
                            <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest opacity-50">Tags</span>
                            <div class="flex flex-wrap gap-2">
                                <button type="button" class="filter-btn min-h-11 px-4 border border-accent bg-accent text-bg font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="tag" data-value="all">All</button>
                            </div>
                        </div>
                        {filterTagGroups.map((group) => (
                            <div class="grid grid-cols-1 sm:grid-cols-[5rem_1fr] gap-3 sm:gap-4 sm:items-center">
                                <span class="font-mono text-[10px] text-text-dim uppercase tracking-widest opacity-50">{group.label}</span>
                                <div class="flex flex-wrap gap-2">
                                    {group.tags.map((tag) => (
                                        <button type="button" class="filter-btn min-h-11 px-4 border border-line text-text-dim hover:text-white hover:border-text-dim font-mono text-[10px] uppercase tracking-widest transition-colors" data-category="tag" data-value={tag}>{tag}</button>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </>
                )}
            </section>
        </div>

        <!-- THE GRID -->
        <div id="grid-container" class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-12 md:gap-y-20">
            {sortedSelections.map(post => (
                <article
                    class="group selection-card border-b border-line/40 pb-10 md:border-b-0 md:pb-0"
                    data-colour={post.data.classification.colour}
                    data-effervescence={post.data.classification.effervescence}
                    data-country={post.data.country}
                    data-tags={flattenSelectionTags(post.data.tags).join('|')}
                    data-price={parsePrice(post.data.price)}
                >
                    <a href={`/selections/${post.id}`} class="block">
                        
                        <!-- THE VIBE CARD -->
                        <div class={`aspect-[4/3] md:aspect-[4/5] relative mb-6 overflow-hidden rounded-sm flex items-center justify-center px-6 py-8 transition duration-500 group-hover:scale-[1.02] ${getSelectionPalette(post.data.palette)}`}>
                            <p class="font-sans text-2xl font-medium uppercase text-center tracking-tight leading-tight">
                                {formatSelectionVibe(post.data.vibe)}
                            </p>
                            
                            <!-- Overlay Tags -->
                            <div class="absolute bottom-4 left-4 flex gap-2 flex-wrap">
                                {flattenSelectionTags(post.data.tags).map(tag => (
                                    <span class="font-mono text-[9px] uppercase tracking-widest border border-current px-1.5 py-0.5 rounded-full">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="flex justify-between items-start gap-4 mb-2">
                            <h2 class="text-2xl font-light text-white group-hover:text-accent transition-colors leading-tight">{post.data.title}</h2>
                            <span class="font-mono text-xs text-text-dim shrink-0 pt-1">{post.data.vintage}</span>
                        </div>
                        
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1 mb-3">
                            <span class="font-mono text-xs text-text-dim uppercase tracking-widest block">{post.data.producer}</span>
                            <span class="font-mono text-[10px] text-text-dim opacity-60">Tasted: {formatDate(post.data.tastingDate)}</span>
                        </div>
                        
                        <!-- Technical Preview -->
                        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[10px] text-text-dim mb-4">
                            <span>{post.data.classification.colour}</span>
                            <span>•</span>
                            <span>{post.data.classification.effervescence}</span>
                            <span>•</span>
                            <span>{post.data.region}</span>
                            <span>•</span>
                            <span>{post.data.price}</span>
                            <span>•</span>
                            <span>{getTotalScore(post.data.metrics)}/10</span>
                        </div>

                        <p class="text-sm text-text-muted font-light leading-relaxed">{post.data.excerpt}</p>

                    </a>
                </article>
            ))}
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-24">
            <p class="text-text-muted font-light text-lg">No wines match the current filters.</p>
            <button id="clear-filters" type="button" class="min-h-11 mt-4 px-4 border border-line font-mono text-[10px] text-text-dim uppercase tracking-widest hover:text-white hover:border-text-dim transition-colors">Clear Filters</button>
        </div>

    </main>
</MainLayout>

<style>
    .filter-btn[aria-pressed="true"],
    #filter-toggle[aria-expanded="true"] {
        border-color: var(--color-accent);
        background: var(--color-accent);
        color: var(--color-bg);
    }

    .filter-btn[aria-pressed="false"] {
        border-color: var(--color-line);
        background: transparent;
        color: var(--color-text-dim);
    }
</style>

<script>
    // Filter State Interface
    interface FilterState {
        colour: string | null;
        effervescence: string | null;
        country: string | null;
        tag: string | null;
        price: string | null; // Stores JSON string of {min, max}
        [key: string]: string | null;
    }

    let activeFilters: FilterState = {
        colour: null,
        effervescence: null,
        country: null,
        tag: null,
        price: null
    };

    // DOM Elements
    const cards = document.querySelectorAll('.selection-card');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const emptyState = document.getElementById('empty-state');
    const clearBtn = document.getElementById('clear-filters');
    const filterToggleBtn = document.getElementById('filter-toggle');
    const filterWrapper = document.getElementById('filter-wrapper');
    const filterToggleText = document.getElementById('filter-toggle-text');

    // Initialize
    function init() {
        // Read URL params
        const params = new URLSearchParams(window.location.search);
        activeFilters.colour = params.get('colour') || null;
        activeFilters.effervescence = params.get('effervescence') || null;
        activeFilters.country = params.get('country') || null;
        activeFilters.tag = params.get('tag') || null;
        activeFilters.price = params.get('price') || null;

        // Auto-open filter if any filter is active
        if (activeFilters.colour || activeFilters.effervescence || activeFilters.country || activeFilters.tag || activeFilters.price) {
            if (filterWrapper && filterToggleText) {
                filterWrapper.classList.remove('max-h-0', 'opacity-0');
                filterWrapper.classList.add('max-h-[1200px]', 'opacity-100');
                filterToggleText.textContent = '[ CLOSE ]';
                filterToggleBtn?.setAttribute('aria-expanded', 'true');
            }
        }

        updateUI();
        applyFilters();
    }

    // Toggle Filter Visibility
    if (filterToggleBtn && filterWrapper && filterToggleText) {
        filterToggleBtn.addEventListener('click', () => {
            if (filterWrapper.classList.contains('max-h-0')) {
                filterWrapper.classList.remove('max-h-0', 'opacity-0');
                filterWrapper.classList.add('max-h-[1200px]', 'opacity-100');
                filterToggleText.textContent = '[ CLOSE ]';
                filterToggleBtn.setAttribute('aria-expanded', 'true');
            } else {
                filterWrapper.classList.add('max-h-0', 'opacity-0');
                filterWrapper.classList.remove('max-h-[1200px]', 'opacity-100');
                filterToggleText.textContent = '[ FILTER ]';
                filterToggleBtn.setAttribute('aria-expanded', 'false');
            }
        });
    }

    // Update Button Styles
    function updateUI() {
        filterBtns.forEach(btn => {
            if (!(btn instanceof HTMLElement)) return;

            const category = btn.dataset.category || '';
            const value = btn.dataset.value || '';
            const isActive = activeFilters[category] === value || (value === 'all' && !activeFilters[category]);

            btn.setAttribute('aria-pressed', String(isActive));
        });
    }

    // Apply Filters to Grid
    function applyFilters() {
        let visibleCount = 0;

        cards.forEach(card => {
            if (!(card instanceof HTMLElement)) return;

            const cardColour = card.dataset.colour;
            const cardEffervescence = card.dataset.effervescence;
            const cardCountry = card.dataset.country;
            const cardTags = (card.dataset.tags || '').split('|').filter(Boolean);
            const cardPrice = parseFloat(card.dataset.price || '0');

            // Price Match Logic
            let matchPrice = true;
            if (activeFilters.price) {
                try {
                    const range = JSON.parse(activeFilters.price);
                    matchPrice = cardPrice >= range.min && cardPrice < range.max;
                } catch (e) {
                    // Fallback if parse fails
                    matchPrice = true;
                }
            }

            const matchColour = !activeFilters.colour || cardColour === activeFilters.colour;
            const matchEffervescence = !activeFilters.effervescence || cardEffervescence === activeFilters.effervescence;
            const matchCountry = !activeFilters.country || cardCountry === activeFilters.country;
            const matchTag = !activeFilters.tag || cardTags.includes(activeFilters.tag);

            if (matchColour && matchEffervescence && matchCountry && matchTag && matchPrice) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });

        // Toggle Empty State
        if (emptyState) {
            if (visibleCount === 0) {
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
            }
        }

        // Update URL
        updateURL();
    }

    // Update URL Params
    function updateURL() {
        const params = new URLSearchParams();
        if (activeFilters.colour) params.set('colour', activeFilters.colour);
        if (activeFilters.effervescence) params.set('effervescence', activeFilters.effervescence);
        if (activeFilters.country) params.set('country', activeFilters.country);
        if (activeFilters.tag) params.set('tag', activeFilters.tag);
        if (activeFilters.price) params.set('price', activeFilters.price);

        const newURL = `${window.location.pathname}${params.toString() ? '?' + params.toString() : ''}`;
        window.history.replaceState({}, '', newURL);
    }

    // Event Listeners
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            if (!(btn instanceof HTMLElement)) return;

            const category = btn.dataset.category || '';
            const value = btn.dataset.value || '';

            if (value === 'all') {
                activeFilters[category] = null;
            } else {
                if (activeFilters[category] === value) {
                    activeFilters[category] = null;
                } else {
                    activeFilters[category] = value;
                }
            }

            updateUI();
            applyFilters();
        });
    });

    if (clearBtn) {
        clearBtn.addEventListener('click', () => {
            activeFilters = {
                colour: null,
                effervescence: null,
                country: null,
                tag: null,
                price: null,
            };
            updateUI();
            applyFilters();
        });
    }

    // Run Init
    init();

    // Listen for back/forward navigation
    window.addEventListener('popstate', init);

</script>
