---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Navigation from '../../components/Navigation.astro';

export async function getStaticPaths() {
  const entries = await getCollection('essays');
  return entries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const getCardBg = (type) => {
    const colors = {
        'Culture': 'bg-[#4A3B32] text-[#E6E2DE]', 
        'Terroir': 'bg-[#3A403A] text-[#E0E5E0]', 
        'Travel': 'bg-[#5D5445] text-[#E6E2DE]',  
        'Journal': 'bg-[#8C5E58] text-[#EBE5E4]'
    };
    return colors[type] || 'bg-[#1A1A1A] text-white';
};

const moodClass = getCardBg(entry.data.type);
---

<MainLayout title={`${entry.data.title} | Enoversa`}>
    <Navigation />

    <main class="min-h-screen pt-32 px-6 md:px-24 pb-24">
        
        <header class="max-w-4xl mx-auto mb-24">
            <div class="flex flex-col md:flex-row justify-between items-end border-b border-line pb-6 mb-12">
                <div>
                    <span class="font-mono text-xs text-accent uppercase tracking-widest mb-2 block">{entry.data.type}</span>
                    <h1 class="text-4xl md:text-6xl font-light tracking-tighter text-white leading-tight">{entry.data.title}</h1>
                </div>
                <span class="font-mono text-xs text-text-dim uppercase mt-4 md:mt-0">{entry.data.location}</span>
            </div>

            <!-- VIBE CARD (Consistent with Index) -->
            <div class={`w-full aspect-[16/9] flex flex-col items-center justify-center rounded-sm relative overflow-hidden ${moodClass}`}>
                
                <!-- Tags -->
                <div class="absolute top-6 left-6 flex gap-2 opacity-60">
                    {entry.data.tags.map(tag => (
                        <span class="font-mono text-[10px] uppercase tracking-widest border border-current px-2 py-0.5 rounded-full">
                            {tag}
                        </span>
                    ))}
                </div>

                <h2 class="text-3xl md:text-5xl font-sans font-medium tracking-tight uppercase text-center max-w-3xl px-8 leading-tight">
                    {entry.data.vibe}
                </h2>
            </div>
        </header>

        <article class="max-w-3xl mx-auto prose prose-invert prose-lg 
            prose-headings:font-light prose-headings:text-white prose-headings:mb-6 prose-headings:mt-16
            prose-p:text-text-muted prose-p:font-light prose-p:leading-relaxed prose-p:mb-8
            prose-strong:font-medium prose-strong:text-white
            prose-blockquote:border-accent prose-blockquote:text-text-main prose-blockquote:font-light prose-blockquote:italic">
            <Content />
        </article>

    </main>
</MainLayout>
