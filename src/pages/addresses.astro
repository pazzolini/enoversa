---
import { getCollection } from "astro:content";
import "maplibre-gl/dist/maplibre-gl.css";
import MainLayout from "../layouts/MainLayout.astro";
import Navigation from "../components/Navigation.astro";
import { comparePlaces } from "../utils/placeSort";

const places = (await getCollection("places")).sort(comparePlaces);

const categoryOrder = ["Winery", "Wine Shop", "Bar", "Restaurant"] as const;
const availableCategories = new Set(places.flatMap((place) => place.data.categories));
const categories = categoryOrder.filter((category) => availableCategories.has(category));
const mappedPlaces = places.map((place, index) => ({
    ...place,
    number: String(index + 1).padStart(2, "0"),
}));

const mapPlaces = mappedPlaces.map((place) => ({
    id: `place-${place.id}`,
    number: place.number,
    title: place.data.title,
    categories: place.data.categories,
    city: place.data.city,
    longitude: place.data.coordinates.longitude,
    latitude: place.data.coordinates.latitude,
}));
---

<MainLayout
    title="Addresses | Enoversa"
    description="Wineries, wine shops, bars and restaurants we would return to."
>
    <Navigation />

    <main id="main-content" class="min-h-screen pt-28 md:pt-32 px-6 md:px-12 lg:px-24 pb-24">
        <header class="max-w-7xl mx-auto mb-12 md:mb-16 border-b border-line pb-10 md:pb-12">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-end">
                <div class="md:col-span-8">
                    <span class="font-mono text-xs text-accent uppercase tracking-widest mb-4 block">
                        04 / Index
                    </span>
                    <h1 class="text-5xl md:text-7xl font-light tracking-tighter text-white">
                        Addresses
                    </h1>
                </div>
                <p class="md:col-span-4 text-text-muted font-light leading-relaxed md:text-right">
                    Places we would return to and addresses we would pass on to a friend.
                </p>
            </div>
        </header>

        <section class="max-w-7xl mx-auto" aria-label="Address map">
            <div class="flex justify-end mb-8">
                <div class="flex flex-wrap gap-2" aria-label="Filter addresses by category">
                    <button
                        type="button"
                        data-place-filter="All"
                        aria-pressed="true"
                        class="place-filter min-h-11 px-4 border border-accent bg-accent text-bg font-mono text-[10px] uppercase tracking-widest transition-colors"
                    >
                        All
                    </button>
                    {categories.map((category) => (
                        <button
                            type="button"
                            data-place-filter={category}
                            aria-pressed="false"
                            class="place-filter min-h-11 px-4 border border-line text-text-dim hover:text-white hover:border-text-dim font-mono text-[10px] uppercase tracking-widest transition-colors"
                        >
                            {category}
                        </button>
                    ))}
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 border-y border-line">
                <div class="map-panel relative z-0 min-w-0 overflow-hidden lg:col-span-8 lg:border-r border-line py-5 lg:py-0">
                    <div class="map-shell relative overflow-hidden bg-surface">
                        <div
                            id="addresses-map"
                            class="absolute inset-0"
                            data-places={JSON.stringify(mapPlaces)}
                            role="region"
                            aria-label="Interactive map of selected addresses. Drag to move and use the controls to zoom."
                        >
                            <p class="map-loading absolute inset-0 grid place-items-center font-mono text-[10px] uppercase tracking-[0.2em] text-text-dim">
                                Loading interactive map…
                            </p>
                            <div
                                class="map-error absolute inset-0 z-10 hidden place-items-center bg-surface px-8 text-center"
                                role="status"
                                aria-live="polite"
                                aria-atomic="true"
                            >
                                <div>
                                    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-muted">
                                        Interactive map unavailable
                                    </p>
                                    <p class="mt-3 text-sm font-light text-text-dim">
                                        The address list and external map links remain available.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="map-instruction absolute left-5 top-5 pointer-events-none">
                            <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-text-muted">
                                Drag to move / Scroll to zoom
                            </span>
                        </div>

                        <p class="map-credit absolute bottom-2 right-3 z-10 font-mono text-[7px] uppercase tracking-wider text-text-dim/70">
                            © <a data-touch-target href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap</a>
                            · <a data-touch-target href="https://www.openmaptiles.org/" target="_blank" rel="noopener noreferrer">OpenMapTiles</a>
                            · <a data-touch-target href="https://openfreemap.org/" target="_blank" rel="noopener noreferrer">OpenFreeMap</a>
                        </p>
                    </div>
                </div>

                <div class="relative z-10 bg-bg lg:col-span-4 lg:max-h-[760px] lg:overflow-y-auto address-list">
                    {mappedPlaces.map((place) => (
                        <article
                            id={`place-${place.id}`}
                            data-place-card
                            data-place-categories={place.data.categories.join("|")}
                            tabindex="-1"
                            class="place-card border-b border-line p-6 md:p-8 transition-colors"
                        >
                            <div class="flex items-start justify-between gap-5">
                                <span class="font-mono text-[10px] text-accent tracking-widest">
                                    {place.number}
                                </span>
                                <div class="text-right">
                                    <span class="block font-mono text-[10px] uppercase tracking-widest text-text-dim">
                                        {place.data.categories.join(" · ")}
                                    </span>
                                </div>
                            </div>

                            <h3 class="mt-8 text-2xl font-light tracking-tight text-white">
                                {place.data.title}
                            </h3>
                            <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-text-dim">
                                {place.data.address ?? place.data.city} · {place.data.country}
                            </p>
                            <p class="mt-6 text-sm text-text-muted font-light leading-relaxed">
                                {place.data.note}
                            </p>

                            <div class="mt-7 pt-5 border-t border-line/70 flex flex-wrap gap-5">
                                    <button
                                        type="button"
                                        data-focus-place
                                        data-place-target={`place-${place.id}`}
                                        data-place-longitude={place.data.coordinates.longitude}
                                        data-place-latitude={place.data.coordinates.latitude}
                                        data-touch-target
                                        class="inline-flex min-h-11 items-center font-mono text-[10px] uppercase tracking-widest text-text-dim hover:text-accent transition-colors"
                                    >
                                        Show on map ↑
                                    </button>
                                    {place.data.relatedUrl && (
                                        <a
                                            href={place.data.relatedUrl}
                                            data-touch-target
                                            class="inline-flex min-h-11 items-center font-mono text-[10px] uppercase tracking-widest text-text-dim hover:text-accent transition-colors"
                                        >
                                            Related story →
                                        </a>
                                    )}
                                    {place.data.website && (
                                        <a
                                            href={place.data.website}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            data-touch-target
                                            class="inline-flex min-h-11 items-center font-mono text-[10px] uppercase tracking-widest text-text-dim hover:text-accent transition-colors"
                                        >
                                            Website ↗
                                        </a>
                                    )}
                                    <a
                                        href={place.data.mapsUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        data-touch-target
                                        class="inline-flex min-h-11 items-center font-mono text-[10px] uppercase tracking-widest text-text-dim hover:text-accent transition-colors"
                                    >
                                        Google Maps ↗
                                    </a>
                            </div>
                        </article>
                    ))}

                    <p id="place-count" aria-live="polite" aria-atomic="true" class="p-6 md:p-8 font-mono text-[10px] uppercase tracking-widest text-text-dim">
                        {mappedPlaces.length} addresses shown
                    </p>
                </div>
            </div>

            <div class="mt-8 flex justify-end text-xs text-text-dim font-light leading-relaxed">
                <p class="max-w-xl md:text-right">
                    No ratings, rankings or paid placements. Just places we think are worth remembering.
                </p>
            </div>
        </section>
    </main>
</MainLayout>

<style>
    .map-shell {
        width: 100%;
        min-width: 0;
        height: clamp(32rem, 52.78vw, 47.5rem);
    }

    #addresses-map {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    :global(.maplibregl-map) {
        font-family: var(--font-sans);
    }

    :global(.maplibregl-canvas:focus-visible) {
        outline: 2px solid var(--color-accent);
        outline-offset: -2px;
    }

    :global(.maplibregl-ctrl-group) {
        overflow: hidden;
        border: 1px solid #3a3a3a;
        border-radius: 0;
        background: rgb(13 13 13 / 92%);
        box-shadow: none;
    }

    :global(.maplibregl-ctrl-group button) {
        width: 44px;
        height: 44px;
    }

    :global(.maplibregl-ctrl-icon) {
        filter: invert(1);
    }

    :global(.maplibregl-ctrl-attrib) {
        display: none !important;
    }

    :global(.maplibregl-cooperative-gesture-screen) {
        background: rgb(5 5 5 / 78%);
        color: #eaeaea;
        font: 10px var(--font-mono);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .map-credit {
        text-shadow: 0 1px 3px #050505;
    }

    .map-credit a:hover {
        color: var(--color-text-muted);
    }

    .map-credit a {
        display: inline-flex;
        min-height: 1.5625rem;
        align-items: center;
    }

    :global(.map-marker) {
        width: 2.75rem;
        height: 2.75rem;
        display: grid;
        place-items: center;
        border: 1px solid var(--color-accent);
        border-radius: 999px;
        background: var(--color-accent);
        color: var(--color-bg);
        font: 600 9px var(--font-mono);
        letter-spacing: 0.08em;
        box-shadow: 0 0 0 5px rgb(5 5 5 / 55%);
        transition: scale 180ms ease, background 180ms ease, color 180ms ease;
        cursor: pointer;
    }

    :global(.map-marker:hover),
    :global(.map-marker:focus-visible),
    :global(.map-marker[data-active="true"]) {
        scale: 1.18;
        background: #eaeaea;
        border-color: #eaeaea;
    }

    .place-card[data-active="true"] {
        background: #171717;
        box-shadow: inset 2px 0 0 var(--color-accent);
    }

    .place-filter[aria-pressed="true"] {
        border-color: var(--color-accent);
        background: var(--color-accent);
        color: var(--color-bg);
    }

    @media (max-width: 1023px) {
        .map-shell {
            aspect-ratio: 4 / 5;
            height: auto;
        }
    }

    @media (max-width: 639px) {
        .map-instruction {
            display: none;
        }
    }
</style>

<script>
    import type { Map as MapLibreMap } from "maplibre-gl";

    const filterButtons = document.querySelectorAll<HTMLButtonElement>("[data-place-filter]");
    const placeCards = document.querySelectorAll<HTMLElement>("[data-place-card]");
    const placeCount = document.getElementById("place-count");
    const mapElement = document.getElementById("addresses-map");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    type MapPlace = {
        id: string;
        number: string;
        title: string;
        categories: string[];
        city: string;
        longitude: number;
        latitude: number;
    };

    let map: MapLibreMap | undefined;
    let loadTimeout: number | undefined;

    const scrollBehavior = () => reducedMotion.matches ? "auto" : "smooth";

    const showMapError = () => {
        if (!mapElement || mapElement.dataset.ready === "true") return;

        if (loadTimeout) window.clearTimeout(loadTimeout);
        mapElement.dataset.error = "true";
        mapElement.querySelector(".map-loading")?.remove();
        mapElement.querySelector<HTMLElement>(".map-error")?.classList.replace("hidden", "grid");
    };

    const selectPlace = (targetId: string) => {
        const placeMarkers = document.querySelectorAll<HTMLButtonElement>("[data-place-marker]");
        placeCards.forEach((card) => delete card.dataset.active);
        placeMarkers.forEach((marker) => delete marker.dataset.active);

        const card = document.getElementById(targetId);
        const marker = document.querySelector<HTMLButtonElement>(`[data-place-marker][data-place-target="${targetId}"]`);
        if (!card) return;

        card.dataset.active = "true";
        if (marker) marker.dataset.active = "true";

        if (window.matchMedia("(max-width: 1023px)").matches) {
            card.scrollIntoView({ behavior: scrollBehavior(), block: "center" });
        }
    };

    const focusMap = (targetId: string, longitude: number, latitude: number) => {
        selectPlace(targetId);
        map?.flyTo({
            center: [longitude, latitude],
            zoom: 10,
            duration: reducedMotion.matches ? 0 : 1100,
        });
    };

    document.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-focus-place]");
        if (!button) return;

        const targetId = button.dataset.placeTarget;
        const longitude = Number(button.dataset.placeLongitude);
        const latitude = Number(button.dataset.placeLatitude);
        if (!targetId || !Number.isFinite(longitude) || !Number.isFinite(latitude)) return;

        focusMap(targetId, longitude, latitude);
        document.getElementById("addresses-map")?.scrollIntoView({
            behavior: scrollBehavior(),
            block: "center",
        });
    });

    filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
            const category = button.dataset.placeFilter ?? "All";
            let visibleCount = 0;

            filterButtons.forEach((filter) => {
                filter.setAttribute("aria-pressed", String(filter === button));
            });

            placeCards.forEach((card) => {
                const cardCategories = (card.dataset.placeCategories ?? "").split("|");
                const visible = category === "All" || cardCategories.includes(category);
                card.hidden = !visible;
                if (visible) visibleCount += 1;
            });

            document.querySelectorAll<HTMLButtonElement>("[data-place-marker]").forEach((marker) => {
                const markerCategories = (marker.dataset.placeCategories ?? "").split("|");
                marker.hidden = category !== "All" && !markerCategories.includes(category);
                delete marker.dataset.active;
            });

            if (placeCount) {
                placeCount.textContent = `${visibleCount} ${visibleCount === 1 ? "address" : "addresses"} shown`;
            }
        });
    });

    const initialiseMap = async () => {
        if (!mapElement || map) return;

        if (!navigator.onLine) {
            showMapError();
            return;
        }

        try {
            const places = JSON.parse(mapElement.dataset.places ?? "[]") as MapPlace[];
            const { default: maplibregl } = await import("maplibre-gl");

            map = new maplibregl.Map({
                container: mapElement,
                style: "https://tiles.openfreemap.org/styles/dark",
                center: [-7.5, 39.5],
                zoom: 3.7,
                minZoom: 2.5,
                maxZoom: 17,
                cooperativeGestures: true,
                attributionControl: false,
            });

            map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");

            places.forEach((place) => {
                const marker = document.createElement("button");
                marker.type = "button";
                marker.className = "map-marker";
                marker.textContent = place.number;
                marker.dataset.placeMarker = "";
                marker.dataset.placeCategories = place.categories.join("|");
                marker.dataset.placeTarget = place.id;
                marker.setAttribute("aria-label", `${place.number}: ${place.title}, ${place.city}`);

                marker.addEventListener("click", () => {
                    focusMap(place.id, place.longitude, place.latitude);
                });

                const nearbyPlaces = places.filter((candidate) => (
                    Math.abs(candidate.latitude - place.latitude) < 0.5
                    && Math.abs(candidate.longitude - place.longitude) < 0.5
                ));
                const nearbyIndex = nearbyPlaces.findIndex((candidate) => candidate.id === place.id);
                const horizontalOffset = (nearbyIndex - (nearbyPlaces.length - 1) / 2) * 54;

                new maplibregl.Marker({ element: marker, offset: [horizontalOffset, 0] })
                    .setLngLat([place.longitude, place.latitude])
                    .addTo(map!);
            });

            loadTimeout = window.setTimeout(showMapError, 10_000);
            map.on("error", () => {
                if (loadTimeout) window.clearTimeout(loadTimeout);
                loadTimeout = window.setTimeout(showMapError, 1500);
            });
            map.on("load", () => {
                if (loadTimeout) window.clearTimeout(loadTimeout);
                if (places.length > 1) {
                    const bounds = places.reduce(
                        (area, place) => area.extend([place.longitude, place.latitude]),
                        new maplibregl.LngLatBounds(),
                    );
                    map?.fitBounds(bounds, { padding: 70, maxZoom: 5, duration: 0 });
                }

                mapElement.dataset.ready = "true";
                mapElement.querySelector(".map-loading")?.remove();

                const initialTarget = window.location.hash.slice(1);
                const initialPlace = places.find((place) => place.id === initialTarget);
                if (initialPlace) {
                    focusMap(initialPlace.id, initialPlace.longitude, initialPlace.latitude);
                }
            });
        } catch {
            showMapError();
        }
    };

    if (mapElement) {
        const observer = new IntersectionObserver((entries) => {
            if (!entries.some((entry) => entry.isIntersecting)) return;
            observer.disconnect();
            void initialiseMap();
        }, { rootMargin: "200px" });

        observer.observe(mapElement);
    }
</script>
