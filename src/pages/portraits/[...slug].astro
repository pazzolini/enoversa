---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Navigation from '../../components/Navigation.astro';
import BackLink from '../../components/BackLink.astro';

export async function getStaticPaths() {
  const entries = await getCollection('portraits');
  return entries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const visitDate = new Intl.DateTimeFormat('en', {
    month: 'long',
    year: 'numeric',
}).format(entry.data.date);
---
<MainLayout title={`${entry.data.title} | Enoversa`}>
    <Navigation />
    <main id="main-content" class="min-h-screen pt-28 md:pt-32 px-6 md:px-24 pb-24">
        <div class="max-w-6xl mx-auto mb-10">
            <BackLink href="/portraits" label="All Portraits" />
        </div>
        <header class={`max-w-6xl mx-auto border-y border-line py-10 md:py-16 ${entry.data.hero ? 'mb-10 md:mb-14' : 'mb-20 md:mb-28'}`}>
            <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">
                <aside class="md:col-span-3 flex md:block justify-between items-start">
                    <span class="font-mono text-[10px] text-accent uppercase tracking-[0.22em]">
                        Portrait / 01
                    </span>
                    <div class="md:mt-28 text-right md:text-left font-mono text-[10px] uppercase tracking-widest text-text-dim leading-relaxed">
                        <span class="block">{visitDate}</span>
                        <span class="block mt-1">{entry.data.location}</span>
                    </div>
                </aside>

                <div class="md:col-span-8 md:col-start-5">
                    <p class="font-mono text-[10px] uppercase tracking-widest text-text-dim mb-4">
                        {entry.data.role}
                    </p>
                    <h1 class="text-4xl sm:text-5xl md:text-7xl font-light tracking-tighter text-white leading-[1.02] break-words">
                        {entry.data.title}
                    </h1>
                    <p class="mt-8 max-w-2xl text-lg md:text-xl text-text-muted font-light leading-relaxed">
                        {entry.data.excerpt}
                    </p>
                    <p class="mt-10 pt-5 border-t border-line/60 font-mono text-[10px] uppercase tracking-widest text-text-dim">
                        {entry.data.tags.join(' · ')}
                    </p>
                </div>
            </div>
        </header>

        {entry.data.hero && (
            <figure class="max-w-6xl mx-auto mb-20 md:mb-28">
                <img
                    src={entry.data.hero.src}
                    srcset={`${entry.data.hero.srcSmall} 1200w, ${entry.data.hero.src} 2400w`}
                    sizes="(max-width: 767px) calc(100vw - 3rem), 72rem"
                    width="2400"
                    height="1600"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    alt={entry.data.hero.alt}
                    class="block w-full h-auto"
                />
                <figcaption class="mt-3 font-mono text-[9px] md:text-[10px] uppercase tracking-widest text-text-dim leading-relaxed">
                    {entry.data.hero.caption}
                </figcaption>
            </figure>
        )}

        <article class="portrait-body max-w-3xl mx-auto prose prose-invert prose-lg prose-headings:font-light prose-headings:text-white prose-headings:mb-6 prose-headings:mt-16 prose-p:text-text-muted prose-p:font-light prose-p:leading-relaxed prose-p:mb-8 prose-strong:font-medium prose-strong:text-white prose-blockquote:border-accent prose-blockquote:text-text-main prose-blockquote:font-light prose-blockquote:italic"><Content /></article>
    </main>
</MainLayout>

<style>
    :global(.portrait-body .portrait-figure) {
        width: min(calc(100vw - 3rem), 72rem);
        margin: 4.5rem 0;
        margin-left: 50%;
        transform: translateX(-50%);
    }

    :global(.portrait-body .portrait-figure img) {
        display: block;
        width: 100%;
        height: auto;
        margin: 0;
    }

    :global(.portrait-body .portrait-figure figcaption) {
        margin-top: 0.75rem;
        color: var(--color-text-dim);
        font-family: var(--font-mono);
        font-size: 0.625rem;
        line-height: 1.5;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    @media (min-width: 768px) {
        :global(.portrait-body .portrait-figure) {
            margin-top: 6rem;
            margin-bottom: 6rem;
        }
    }
</style>
