---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Navigation from '../../components/Navigation.astro';

const allPortraits = await getCollection('portraits');
const sortedPortraits = allPortraits.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getMoodColor = (tag) => {
    const colors = {
        'Interview': 'bg-[#8C5E58] text-[#EBE5E4]',
        'Pessoas do Vinho': 'bg-[#586F7C] text-[#E0E7EB]',
        'Career': 'bg-[#4A403A] text-[#E6E2DE]',
    };
    return colors[tag] || 'bg-[#2A2A2A] text-white';
};
---
<MainLayout title="Portraits | Enoversa">
    <Navigation />
    <main class="min-h-screen pt-32 px-6 md:px-24 pb-24">
        <header class="max-w-7xl mx-auto mb-24 border-b border-line pb-12">
            <div class="flex flex-col md:flex-row justify-between items-end">
                <div><span class="font-mono text-xs text-accent uppercase tracking-widest mb-4 block">02 / Index</span><h1 class="text-5xl md:text-7xl font-light tracking-tighter text-white">Portraits</h1></div>
                <p class="text-text-muted font-light text-right mt-4 md:mt-0 max-w-xs">Narrative profiles of the makers, the growers, and the thinkers.</p>
            </div>
        </header>
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-20">
            {sortedPortraits.map(post => (
                <article class="group cursor-pointer">
                    <a href={`/portraits/${post.slug}`} class="block">
                        <div class={`aspect-[4/5] relative mb-6 overflow-hidden flex flex-col items-center justify-center px-6 py-8 transition duration-500 group-hover:scale-[1.02] ${getMoodColor(post.data.tags[0])}`}>
                            <span class="font-mono text-[10px] uppercase tracking-widest opacity-60 mb-4">{post.data.role}</span>
                            <h3 class="font-sans text-3xl font-medium text-center tracking-tight leading-tight">{post.data.title}</h3>
                        </div>
                        <div class="flex justify-between items-baseline mb-2"><h3 class="text-xl font-light text-white group-hover:text-accent transition-colors">{post.data.title}</h3><span class="font-mono text-xs text-text-dim">{post.data.location}</span></div>
                        <p class="text-text-muted font-light text-sm leading-relaxed line-clamp-3 mb-4">{post.data.excerpt}</p>
                        <span class="text-xs font-mono uppercase tracking-wider text-text-dim border-b border-transparent group-hover:border-accent group-hover:text-accent transition inline-block pb-0.5">Read Profile -></span>
                    </a>
                </article>
            ))}
        </div>
    </main>
</MainLayout>
