---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Navigation from '../../components/Navigation.astro';

const allPortraits = await getCollection('portraits');
const sortedPortraits = allPortraits.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatVisitDate = (date: Date) => new Intl.DateTimeFormat('en', {
    month: 'long',
    year: 'numeric',
}).format(date);
---
<MainLayout title="Portraits | Enoversa">
    <Navigation />
    <main id="main-content" class="min-h-screen pt-28 md:pt-32 px-6 md:px-24 pb-24">
        <header class="max-w-7xl mx-auto mb-24 border-b border-line pb-12">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end">
                <div><span class="font-mono text-xs text-accent uppercase tracking-widest mb-4 block">02 / Index</span><h1 class="text-5xl md:text-7xl font-light tracking-tighter text-white">Portraits</h1></div>
                <p class="text-text-muted font-light text-left md:text-right mt-4 md:mt-0 max-w-xs">Conversations with growers, winemakers, and people working around wine.</p>
            </div>
        </header>
        {sortedPortraits.length > 0 ? (
            <div class="max-w-7xl mx-auto border-t border-line">
                {sortedPortraits.map((post, index) => (
                    <article class="group border-b border-line">
                        <a
                            href={`/portraits/${post.id}`}
                            class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 py-10 md:py-14"
                        >
                            <div class="md:col-span-2 flex md:block justify-between items-start">
                                <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-accent">
                                    Portrait / {String(index + 1).padStart(2, '0')}
                                </span>
                                <span class="md:mt-16 block font-mono text-[10px] uppercase tracking-widest text-text-dim">
                                    {formatVisitDate(post.data.date)}
                                </span>
                            </div>
                            <div class="md:col-span-6">
                                <h2 class="text-3xl md:text-5xl font-light tracking-tight text-white group-hover:text-accent transition-colors">
                                    {post.data.title}
                                </h2>
                                <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-text-dim leading-relaxed">
                                    <span class="block">{post.data.role}</span>
                                    <span class="block mt-1">{post.data.location}</span>
                                </p>
                                <p class="mt-6 max-w-2xl text-text-muted font-light leading-relaxed">
                                    {post.data.excerpt}
                                </p>
                            </div>
                            <div class="md:col-span-3 md:col-start-10 flex flex-col justify-between items-start md:items-end gap-6">
                                <span class="font-mono text-[10px] uppercase tracking-widest text-text-dim md:text-right">
                                    {post.data.tags.join(' · ')}
                                </span>
                                <span class="font-mono text-xs uppercase tracking-wider text-text-dim group-hover:text-white transition-colors">
                                    Read Portrait ->
                                </span>
                            </div>
                        </a>
                    </article>
                ))}
            </div>
        ) : (
            <div class="max-w-7xl mx-auto border-y border-line py-16">
                <p class="max-w-xl text-xl font-light text-text-muted">
                    No portraits have been published in Volume II yet.
                </p>
                <a
                    href="https://legacy.enoversa.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-6 min-h-11 inline-flex items-center font-mono text-xs uppercase tracking-widest text-accent hover:text-white transition-colors"
                >
                    Read earlier interviews in the Legacy Archive ↗
                </a>
            </div>
        )}
    </main>
</MainLayout>
