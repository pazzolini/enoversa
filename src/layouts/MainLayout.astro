---
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const {
    title,
    description = "Narratives of Soil & Craft. A digital journal exploring low-intervention wines.",
    image = "/favicon.png",
} = Astro.props;

const siteUrl = "https://enoversa.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const fullImage = image.startsWith("http") ? image : `${siteUrl}${image}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth antialiased">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" type="application/rss+xml" title="Enoversa RSS" href="/rss.xml" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#050505" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="author" content="Vítor & Catarina" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={fullImage} />
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalUrl} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={fullImage} />

    </head>
    <body class="bg-bg text-text-main noise-bg font-sans">
        <a class="skip-link" href="#main-content">Skip to content</a>
        <!-- ELEMENTO DO CURSOR -->
        <div id="cursor" class="custom-cursor"></div>

        <slot />

        <footer
            class="px-6 md:px-24 py-12 border-t border-line flex flex-col md:flex-row justify-between items-start md:items-end text-accent font-mono text-xs"
        >
            <div class="flex flex-col gap-4 mb-8 md:mb-0">
                <a
                    href="https://instagram.com/enoversa"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Enoversa on Instagram (opens in a new tab)"
                    class="inline-flex min-h-11 items-center hover:text-white transition"
                >
                    Instagram ↗
                </a>
                <a
                    href="mailto:info@enoversa.com"
                    class="hover:text-white transition">info@enoversa.com</a
                >
            </div>
            <div class="text-right opacity-60 text-text-dim">
                <p>© {new Date().getFullYear()} ENOVERSA</p>
                <p>Porto, Portugal</p>
            </div>
        </footer>

        <!-- SCRIPT DO CURSOR -->
        <script>
            const cursor = document.getElementById("cursor");
            const body = document.body;

            // Mover o cursor
            const finePointer = window.matchMedia(
                "(hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)",
            );

            document.addEventListener("mousemove", (e) => {
                if (!finePointer.matches) return;
                if (cursor) {
                    cursor.style.left = e.clientX + "px";
                    cursor.style.top = e.clientY + "px";
                }
            });

            // Efeito Hover em Links
            const links = document.querySelectorAll(
                "a, button, .cursor-pointer",
            );
            links.forEach((link) => {
                link.addEventListener("mouseenter", () => {
                    body.classList.add("hovering");
                });
                link.addEventListener("mouseleave", () => {
                    body.classList.remove("hovering");
                });
            });
        </script>
    </body>
</html>
