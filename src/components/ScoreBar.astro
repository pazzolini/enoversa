---
interface Props {
  score: number;
}
const { score } = Astro.props;
---
<div class="flex gap-1 h-2 w-24" role="img" aria-label={`Score ${score} out of 2`}>
    <div class={`flex-1 transition-all ${score >= 1 ? 'bg-accent' : 'bg-line'}`}></div>
    <div class={`flex-1 transition-all ${score >= 2 ? 'bg-accent' : 'bg-line'}`}></div>
</div>
